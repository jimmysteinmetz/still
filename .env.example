# Local-only environment for `still`. Copy to `.env` (gitignored) and fill in.
# `still` auto-loads `.env` on startup. In production these values come from
# Secret Manager → the Cloud Run env, not this file.

# Gemini (the editorial pass). Default auth is Vertex AI + ADC: set your GCP
# project here and run `gcloud auth application-default login` once. Or set
# GEMINI_API_KEY instead to use the Developer API.
GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global    # Gemini publisher models live on `global`
# GEMINI_API_KEY=                 # opt into the Developer API instead of Vertex + ADC
# STILL_GEMINI_MODEL=gemini-3.5-flash

# Upcoming Shows card (SeatGeek). Free client_id: https://seatgeek.com/account/develop
# Without it, the Shows card simply hides — nothing else is affected.
SEATGEEK_CLIENT_ID=

# Your Day masthead line (Google Calendar OAuth). Both paths default under the
# gitignored data/. The client JSON is only needed for the one-time
# `still calendar auth`; the token it writes is self-contained and is all the
# daily build needs. Without a token, the line simply omits.
# GOOGLE_CALENDAR_CLIENT=data/google_calendar_client.json
# GOOGLE_CALENDAR_TOKEN=data/google_calendar_token.json

# Reddit ingestion (Phase 3). Create a "script" type app at
# https://www.reddit.com/prefs/apps to get a client_id/secret. Without both,
# configured reddit sources are simply skipped — nothing else is affected.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=still:personal-newspaper:v0.1 (by /u/YOUR_USERNAME)

# scripts/spotify_pull.py — one-off pull to bias the Shows card + Music & Shows
# news toward artists you actually listen to. NOT part of the daily pipeline;
# only used when you manually run that script. Create an app at
# https://developer.spotify.com/dashboard with redirect URI
# http://127.0.0.1:8888/callback to get a client_id. client_secret is optional
# (the script uses Authorization Code + PKCE, which works with client_id alone).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
